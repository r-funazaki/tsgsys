<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>払込取扱票 突合システム</title>

<!-- 外部ライブラリ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/encoding-japanese/2.0.0/encoding.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<style>
  :root {
    --bg: #f4f5f7;
    --panel: #ffffff;
    --ink: #1a1f2e;
    --ink-soft: #5a6478;
    --border: #d8dde6;
    --border-soft: #e8ecf2;
    --accent: #1f4ea8;
    --accent-dark: #173a82;
    --ok: #1d8348;
    --ok-bg: #e8f5ee;
    --ng: #b03030;
    --ng-bg: #fbeaea;
    --warn: #b07300;
    --warn-bg: #fcf3df;
    --shadow: 0 1px 2px rgba(20,30,60,.04), 0 4px 12px rgba(20,30,60,.06);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: "Hiragino Kaku Gothic ProN", "Yu Gothic", "Meiryo", sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 14px;
    line-height: 1.6;
  }

  /* ヘッダ */
  header.app-header {
    background: linear-gradient(180deg, #1a3a78 0%, #1f4ea8 100%);
    color: #fff;
    padding: 18px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 2px 6px rgba(0,0,0,.1);
  }
  .app-header h1 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .app-header .sub {
    font-size: 12px;
    opacity: 0.85;
    margin-top: 2px;
  }
  .app-header .right {
    font-size: 12px;
    opacity: 0.9;
  }

  /* レイアウト */
  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 28px 60px;
  }

  /* セクション */
  .section {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .section-title {
    padding: 12px 18px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border-soft);
    font-weight: 600;
    font-size: 13px;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-title::before {
    content: "";
    width: 4px;
    height: 14px;
    background: var(--accent);
    border-radius: 2px;
  }
  .section-body {
    padding: 18px;
  }

  /* 取込エリア */
  .import-grid {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 16px;
    align-items: stretch;
  }
  @media (max-width: 800px) {
    .import-grid { grid-template-columns: 1fr; }
  }
  .file-card {
    border: 1.5px dashed var(--border);
    border-radius: 6px;
    padding: 14px 16px;
    background: #fafbfd;
    transition: border-color .15s;
  }
  .file-card.loaded {
    border-style: solid;
    border-color: var(--ok);
    background: var(--ok-bg);
  }
  .file-card .label {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .file-card .filename {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    word-break: break-all;
    min-height: 20px;
  }
  .file-card .meta {
    font-size: 11px;
    color: var(--ink-soft);
    margin-top: 4px;
  }
  .file-card input[type="file"] {
    display: none;
  }

  /* ボタン */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--ink);
    border-radius: 4px;
    cursor: pointer;
    transition: all .12s;
    font-family: inherit;
    white-space: nowrap;
  }
  .btn:hover:not(:disabled) {
    background: #f0f3f8;
    border-color: #b8c0d0;
  }
  .btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .btn-primary:hover:not(:disabled) {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }
  .btn-large {
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
  }
  .btn-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* アクションバー */
  .action-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }
  .action-bar .spacer { flex: 1; }

  /* サマリー */
  .summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }
  @media (max-width: 700px) {
    .summary { grid-template-columns: repeat(2, 1fr); }
  }
  .stat {
    background: #f8fafc;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    padding: 12px 14px;
  }
  .stat .stat-label {
    font-size: 11px;
    color: var(--ink-soft);
    margin-bottom: 4px;
  }
  .stat .stat-value {
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    font-feature-settings: "tnum";
  }
  .stat.ok .stat-value { color: var(--ok); }
  .stat.ng .stat-value { color: var(--ng); }
  .stat.warn .stat-value { color: var(--warn); }

  /* テーブル */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
  }
  table.result-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  table.result-table th,
  table.result-table td {
    padding: 9px 12px;
    border-bottom: 1px solid var(--border-soft);
    text-align: left;
    vertical-align: middle;
  }
  table.result-table th {
    background: #f5f7fb;
    font-weight: 600;
    color: var(--ink-soft);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    white-space: nowrap;
    border-bottom: 2px solid var(--border);
  }
  table.result-table tr:last-child td { border-bottom: none; }
  table.result-table tr:hover td { background: #fafbfd; }
  table.result-table td.num {
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
  }
  .badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }
  .badge.ok { background: var(--ok-bg); color: var(--ok); }
  .badge.ng { background: var(--ng-bg); color: var(--ng); }
  .badge.warn { background: var(--warn-bg); color: var(--warn); }
  .badge.neutral { background: #eef1f6; color: var(--ink-soft); }

  .preview-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 12px;
    cursor: pointer;
  }
  .preview-link:hover { text-decoration: underline; }

  /* モーダル(プレビュー) */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,20,35,.6);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 24px;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: #fff;
    border-radius: 8px;
    max-width: 90vw;
    max-height: 90vh;
    overflow: auto;
    box-shadow: 0 12px 48px rgba(0,0,0,.4);
    position: relative;
  }
  .modal-header {
    padding: 12px 18px;
    border-bottom: 1px solid var(--border-soft);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1;
  }
  .modal-title { font-weight: 600; font-size: 14px; }
  .modal-close {
    background: none;
    border: none;
    font-size: 22px;
    cursor: pointer;
    color: var(--ink-soft);
    padding: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }
  .modal-close:hover { background: #f0f3f8; }
  .modal-body { padding: 18px; }
  .modal-body img,
  .modal-body canvas {
    max-width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--border-soft);
  }

  /* ローディング */
  .loading {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: #fff7e0;
    border: 1px solid #f0d480;
    border-radius: 4px;
    color: #8a6500;
    font-size: 13px;
    margin-bottom: 12px;
  }
  .loading.show { display: flex; }
  .spinner {
    width: 14px;
    height: 14px;
    border: 2px solid #f0d480;
    border-top-color: #8a6500;
    border-radius: 50%;
    animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--ink-soft);
    font-size: 13px;
  }
  .empty-state .icon {
    font-size: 32px;
    opacity: 0.4;
    margin-bottom: 8px;
  }

  /* 印刷用 */
  @media print {
    body { background: #fff; }
    header.app-header,
    #importSection,
    #actionBar,
    .no-print { display: none !important; }
    main { padding: 0; max-width: none; }
    .section {
      box-shadow: none;
      border: 1px solid #ccc;
      page-break-inside: avoid;
    }
    .section-title { background: #eee !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .badge.ok { background: #dfd !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .badge.ng { background: #fdd !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .badge.warn { background: #ffd !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    table.result-table { font-size: 11px; }
    table.result-table th { background: #f0f0f0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
</head>
<body>

<header class="app-header">
  <div>
    <h1>払込取扱票 突合システム</h1>
    <div class="sub">PDF×CSV 一連番号・取扱店 突合チェック</div>
  </div>
  <div class="right" id="dateDisplay"></div>
</header>

<main>

  <!-- ① 取込セクション -->
  <section class="section" id="importSection">
    <div class="section-title">① ファイル取込</div>
    <div class="section-body">
      <div class="import-grid">
        <label class="file-card" id="pdfCard" for="pdfInput">
          <div class="label">PDF ファイル (払込取扱票)</div>
          <div class="filename" id="pdfFilename">未選択 — クリックして選択</div>
          <div class="meta" id="pdfMeta">&nbsp;</div>
          <input type="file" id="pdfInput" accept=".pdf,application/pdf" />
        </label>

        <label class="file-card" id="csvCard" for="csvInput">
          <div class="label">CSV ファイル (入金明細)</div>
          <div class="filename" id="csvFilename">未選択 — クリックして選択</div>
          <div class="meta" id="csvMeta">&nbsp;</div>
          <input type="file" id="csvInput" accept=".csv,text/csv" />
        </label>

        <div style="display:flex; align-items:flex-end;">
          <button class="btn btn-primary btn-large" id="btnImport" disabled>取込</button>
        </div>
      </div>

      <div class="loading" id="importLoading">
        <div class="spinner"></div>
        <div id="importLoadingText">処理中…</div>
      </div>
    </div>
  </section>

  <!-- ② 突合・結果セクション -->
  <section class="section">
    <div class="section-title">② 突合結果</div>
    <div class="section-body">

      <div class="action-bar" id="actionBar" style="margin-bottom: 16px;">
        <button class="btn btn-primary" id="btnMatch" disabled>突合実行</button>
        <div class="spacer"></div>
        <button class="btn" id="btnExcel" disabled>
          <svg class="btn-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-3 14h-2.5l-2-3.05L9.5 17H7l3.7-5.5L7.2 6h2.5l1.8 3 1.8-3h2.5l-3.5 5.5L16 17z"/></svg>
          Excelダウンロード
        </button>
        <button class="btn" id="btnPdfZip" disabled>
          <svg class="btn-icon" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 13h8v2H8v-2zm0 4h8v2H8v-2z"/></svg>
          PDFを分割ダウンロード(ZIP)
        </button>
        <button class="btn" id="btnPrint" disabled>
          <svg class="btn-icon" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg>
          印刷
        </button>
      </div>

      <div id="summarySection" style="display:none;">
        <div class="summary">
          <div class="stat"><div class="stat-label">PDF 取扱票件数</div><div class="stat-value" id="statPdf">0</div></div>
          <div class="stat"><div class="stat-label">CSV 明細件数</div><div class="stat-value" id="statCsv">0</div></div>
          <div class="stat ok"><div class="stat-label">一致</div><div class="stat-value" id="statOk">0</div></div>
          <div class="stat ng"><div class="stat-label">不一致</div><div class="stat-value" id="statNg">0</div></div>
        </div>
      </div>

      <div id="resultArea">
        <div class="empty-state">
          <div class="icon">📋</div>
          <div>PDFとCSVを取込後、「突合実行」ボタンを押してください</div>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- プレビューモーダル -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modalTitle">プレビュー</div>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<script>
// ========== グローバル状態 ==========
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

const state = {
  pdfFile: null,
  csvFile: null,
  pdfDoc: null,           // pdf.js のドキュメント
  pdfBytes: null,         // pdf-lib 用の元バイト列
  pdfPages: [],           // [{pageIndex, slipNumber, branch, payer, address, amount, fee, memberNo, products, canvasDataUrl, isSlip}]
  csvRows: [],            // [{slipNumber, branch}]
  matchResults: [],       // 突合結果
};

// ========== 日付表示 ==========
(function showDate() {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  document.getElementById('dateDisplay').textContent = `${y}年${m}月${day}日`;
})();

// ========== ファイル選択 ==========
const pdfInput = document.getElementById('pdfInput');
const csvInput = document.getElementById('csvInput');
const pdfCard = document.getElementById('pdfCard');
const csvCard = document.getElementById('csvCard');
const btnImport = document.getElementById('btnImport');

pdfInput.addEventListener('change', (e) => {
  const f = e.target.files[0];
  if (!f) return;
  state.pdfFile = f;
  document.getElementById('pdfFilename').textContent = f.name;
  document.getElementById('pdfMeta').textContent = `${(f.size / 1024).toFixed(1)} KB`;
  pdfCard.classList.add('loaded');
  updateImportButton();
});

csvInput.addEventListener('change', (e) => {
  const f = e.target.files[0];
  if (!f) return;
  state.csvFile = f;
  document.getElementById('csvFilename').textContent = f.name;
  document.getElementById('csvMeta').textContent = `${(f.size / 1024).toFixed(1)} KB`;
  csvCard.classList.add('loaded');
  updateImportButton();
});

function updateImportButton() {
  btnImport.disabled = !(state.pdfFile && state.csvFile);
}

// ========== 取込ボタン ==========
btnImport.addEventListener('click', async () => {
  showLoading('取込処理中… (PDFを解析しています)');
  try {
    await Promise.all([loadCsv(), loadPdf()]);
    document.getElementById('btnMatch').disabled = false;
    document.getElementById('btnPdfZip').disabled = false;
    showLoading(false);
    alert(`取込完了\nPDF: ${state.pdfPages.length} ページ (うち取扱票 ${state.pdfPages.filter(p => p.isSlip).length} 件)\nCSV: ${state.csvRows.length} 件`);
  } catch (err) {
    showLoading(false);
    alert('取込エラー: ' + err.message);
    console.error(err);
  }
});

function showLoading(msgOrFalse) {
  const el = document.getElementById('importLoading');
  if (msgOrFalse === false) {
    el.classList.remove('show');
  } else {
    document.getElementById('importLoadingText').textContent = msgOrFalse;
    el.classList.add('show');
  }
}

// ========== CSV読込 (Shift_JIS / UTF-8 自動判定) ==========
async function loadCsv() {
  const buf = await state.csvFile.arrayBuffer();
  const u8 = new Uint8Array(buf);

  // 文字コード判定
  let detected = Encoding.detect(u8);
  if (!detected || detected === 'BINARY') detected = 'SJIS';

  let text;
  if (detected === 'UTF8') {
    text = new TextDecoder('utf-8').decode(u8);
  } else {
    // SJIS / EUCJP など
    const unicodeArr = Encoding.convert(u8, { to: 'UNICODE', from: detected });
    text = Encoding.codeToString(unicodeArr);
  }

  const parsed = Papa.parse(text.trim(), { header: true, skipEmptyLines: true });
  if (parsed.errors.length) {
    console.warn('CSV parse warnings:', parsed.errors);
  }

  // ヘッダの揺れに対応
  state.csvRows = parsed.data.map(row => {
    // キー名のトリムと正規化
    const normalized = {};
    Object.keys(row).forEach(k => {
      normalized[k.trim()] = String(row[k]).trim();
    });
    const slipNumber = normalized['一連番号'] || normalized['一連番号 '] || normalized['slip'] || '';
    const branch = normalized['取扱店'] || normalized['branch'] || '';
    return {
      slipNumber: slipNumber.replace(/\s/g, ''),
      branch: branch.trim(),
      raw: normalized,
    };
  }).filter(r => r.slipNumber);
}

// ========== PDF読込・解析 ==========
async function loadPdf() {
  const buf = await state.pdfFile.arrayBuffer();
  state.pdfBytes = buf.slice(0); // pdf-lib 用に保存

  const loadingTask = pdfjsLib.getDocument({ data: new Uint8Array(buf) });
  state.pdfDoc = await loadingTask.promise;

  state.pdfPages = [];
  for (let i = 1; i <= state.pdfDoc.numPages; i++) {
    showLoading(`PDFを解析中… (${i}/${state.pdfDoc.numPages})`);
    const page = await state.pdfDoc.getPage(i);
    const info = await extractPageInfo(page, i);
    state.pdfPages.push(info);
  }
}

// ========== ページ情報抽出 ==========
// 全角英数→半角、全角スペース→半角スペース正規化
function normalizeText(s) {
  return s
    .replace(/[０-９]/g, c => String.fromCharCode(c.charCodeAt(0) - 0xFEE0))
    .replace(/[Ａ-Ｚａ-ｚ]/g, c => String.fromCharCode(c.charCodeAt(0) - 0xFEE0))
    .replace(/[ー－―]/g, '-')
    .replace(/\u3000/g, ' ')
    .replace(/‑/g, '-');
}

async function extractPageInfo(page, pageIndex) {
  // テキスト抽出
  const textContent = await page.getTextContent();
  const items = textContent.items
    .map(it => ({ str: it.str, x: it.transform[4], y: it.transform[5] }))
    .filter(it => it.str && it.str.trim());

  // 全テキスト(原文)
  const rawText = items.map(i => i.str).join('\n');
  // 正規化
  const allText = normalizeText(rawText);
  // スペース・改行を全て除去した版(ラベル・数字抽出に使用)
  const compactText = allText.replace(/\s+/g, '');
  // 行配列(振込者抽出など、行構造が必要なケース用)
  const lines = allText.split('\n').map(l => l.trim()).filter(l => l);

  // ---------- ページ種別判定 ----------
  // 払込取扱票本体は画像のため、「払込取扱票」というラベル自体はテキスト抽出されない。
  // テキストレイヤーから抽出できるのは右側の伝票データ部分のみで、
  // 「取扱店」ラベル + 「(99999)」のような5桁取扱局コードがあれば払込取扱票と判定。
  const hasShopLabel = /取扱店/.test(compactText);
  const hasShopCode = /\(\d{5}\)/.test(compactText);
  const isFurikae = /振替受入明細票|電信振替/.test(compactText) ||
                    (/金額[\d,]+/.test(compactText) && !hasShopLabel && /[都道府県].*[市区町村]/.test(allText));
  const isSummary = (/振替受払通知票/.test(compactText) || /通知番号及び越高/.test(compactText)) && !hasShopLabel && !isFurikae;
  const isSlip = hasShopLabel && hasShopCode && !isFurikae;

  // ---------- 一連番号(8桁) ----------
  // 戦略: 口座番号「00100-0-XXXXXX」のXXXXXXを特定し、
  //       compactText 内でその直後に続く数字列の末尾8桁を一連番号として採用。
  // PDFテキスト構造の例: "001000-99999911300011令和..." → trailing="11300011"
  let slipNumber = '';
  const acctMatch = compactText.match(/00100-?0-?(\d{6})/);
  const accountNumber = acctMatch ? acctMatch[1] : null;

  if (accountNumber) {
    const re = new RegExp(`00100-?0-?${accountNumber}(\\d+)`);
    const m = compactText.match(re);
    if (m && m[1].length >= 8) {
      slipNumber = m[1].slice(-8);
    }
    // 数字が分割されている場合のフォールバック
    if (!slipNumber) {
      const afterAcct = compactText.split(accountNumber)[1] || '';
      const beforeReiwa = afterAcct.split('令和')[0];
      const allDigits = (beforeReiwa.match(/\d+/g) || []).join('');
      if (allDigits.length >= 8) slipNumber = allDigits.slice(-8);
    }
  }
  // 最終フォールバック: 独立した8桁数字
  if (!slipNumber) {
    const numberRuns = compactText.match(/\d+/g) || [];
    for (const n of numberRuns) {
      if (n.length === 8 && !/^0+$/.test(n) && !/^(\d)\1+$/.test(n)) {
        if (accountNumber && n.includes(accountNumber)) continue;
        slipNumber = n;
        break;
      }
    }
  }

  // ---------- 取扱店 ----------
  let branch = '';
  const branchMatch = compactText.match(/取扱店([\u4E00-\u9FFF\u3040-\u30FF]{1,10})/);
  if (branchMatch) branch = branchMatch[1];

  // ---------- 払込金額(11桁0埋め形式) ----------
  let amount = '';
  const reiwaIdx = compactText.search(/令和/);
  const shopIdx = compactText.search(/取扱店/);
  if (reiwaIdx >= 0 && shopIdx > reiwaIdx) {
    const segment = compactText.substring(reiwaIdx, shopIdx);
    const padded = segment.match(/0{4,}(\d+)/);
    if (padded) amount = padded[1];
  }
  // 振替受入明細票形式: "金額12,000"
  if (!amount) {
    const amtComma = compactText.match(/金額([\d,]+)/);
    if (amtComma) amount = amtComma[1].replace(/,/g, '');
  }

  // ---------- 振込者(振替受入明細票のみテキスト抽出可能) ----------
  // 通常の払込取扱票は手書き欄が画像のため、テキスト抽出は不可。
  // ユーザーは「振込者はPDF画像から確認する」要件のため、画像プレビュー機能で対応。
  let payer = '';
  let address = '';
  if (isFurikae || (!isSlip && !isSummary)) {
    // 郵便番号 → 住所 → 名前 のパターン
    for (let i = 0; i < lines.length; i++) {
      if (/^\d{3}-\d{4}$/.test(lines[i].trim())) {
        const after = lines.slice(i + 1, Math.min(lines.length, i + 8));
        const addrParts = [];
        let nameStart = -1;
        for (let k = 0; k < after.length; k++) {
          if (/[都道府県]|丁目|番地|^\d/.test(after[k])) {
            addrParts.push(after[k].trim());
          } else if (/[\u4E00-\u9FFF\u3040-\u30FF]/.test(after[k]) && !/通信|料金|金額|円|電話/.test(after[k])) {
            nameStart = k; break;
          }
        }
        address = addrParts.join('').replace(/\s+/g, '');
        if (nameStart >= 0) {
          const nameParts = [after[nameStart].trim()];
          if (nameStart + 1 < after.length) {
            const next = after[nameStart + 1].trim();
            if (/[\u4E00-\u9FFF\u3040-\u30FF]/.test(next) && !/通信|料金|電話/.test(next) && next.length < 8) {
              nameParts.push(next);
            }
          }
          payer = nameParts.join(' ').trim();
        }
        break;
      }
    }
  }

  // ---------- ページ画像をCanvasに描画 (プレビュー用) ----------
  const viewport = page.getViewport({ scale: 1.5 });
  const canvas = document.createElement('canvas');
  canvas.width = viewport.width;
  canvas.height = viewport.height;
  const ctx = canvas.getContext('2d');
  await page.render({ canvasContext: ctx, viewport }).promise;
  const canvasDataUrl = canvas.toDataURL('image/jpeg', 0.7);

  return {
    pageIndex,
    pageType: isSlip ? '払込取扱票' : (isFurikae ? '振替受入明細票' : (isSummary ? 'サマリ' : 'その他')),
    isSlip,
    isFurikae,
    isSummary,
    slipNumber,
    branch,
    payer,
    address,
    amount,
    fee: '',
    memberNo: '',
    canvasDataUrl,
    rawText: allText,
  };
}

// ========== 突合実行 ==========
document.getElementById('btnMatch').addEventListener('click', () => {
  doMatch();
});

function doMatch() {
  const results = [];

  // PDFページ単位で突合 (取扱票のみ対象。サマリページは除外)
  const slipPages = state.pdfPages.filter(p => p.isSlip || p.isFurikae);
  const usedCsvIdx = new Set();

  slipPages.forEach(pg => {
    // CSVを slipNumber で検索
    const csvIdx = state.csvRows.findIndex((r, idx) => !usedCsvIdx.has(idx) && r.slipNumber === pg.slipNumber);
    if (csvIdx >= 0) {
      const csv = state.csvRows[csvIdx];
      usedCsvIdx.add(csvIdx);
      const branchOk = csv.branch === pg.branch;
      const slipOk = csv.slipNumber === pg.slipNumber;
      const allOk = branchOk && slipOk;
      results.push({
        type: 'matched',
        status: allOk ? 'OK' : 'NG',
        pdfPage: pg.pageIndex,
        pdfSlip: pg.slipNumber,
        pdfBranch: pg.branch,
        pdfPayer: pg.payer,
        pdfAmount: pg.amount,
        csvSlip: csv.slipNumber,
        csvBranch: csv.branch,
        slipMatch: slipOk,
        branchMatch: branchOk,
        pdfPageRef: pg,
      });
    } else {
      results.push({
        type: 'pdf_only',
        status: 'NG',
        pdfPage: pg.pageIndex,
        pdfSlip: pg.slipNumber,
        pdfBranch: pg.branch,
        pdfPayer: pg.payer,
        pdfAmount: pg.amount,
        csvSlip: '',
        csvBranch: '',
        slipMatch: false,
        branchMatch: false,
        pdfPageRef: pg,
      });
    }
  });

  // CSVに残っている = PDFに対応がない
  state.csvRows.forEach((r, idx) => {
    if (!usedCsvIdx.has(idx)) {
      results.push({
        type: 'csv_only',
        status: 'NG',
        pdfPage: null,
        pdfSlip: '',
        pdfBranch: '',
        pdfPayer: '',
        pdfAmount: '',
        csvSlip: r.slipNumber,
        csvBranch: r.branch,
        slipMatch: false,
        branchMatch: false,
        pdfPageRef: null,
      });
    }
  });

  state.matchResults = results;
  renderResults();

  document.getElementById('btnExcel').disabled = false;
  document.getElementById('btnPrint').disabled = false;
}

// ========== 結果描画 ==========
function renderResults() {
  const results = state.matchResults;
  document.getElementById('summarySection').style.display = 'block';
  document.getElementById('statPdf').textContent = state.pdfPages.filter(p => p.isSlip || p.isFurikae).length;
  document.getElementById('statCsv').textContent = state.csvRows.length;
  document.getElementById('statOk').textContent = results.filter(r => r.status === 'OK').length;
  document.getElementById('statNg').textContent = results.filter(r => r.status === 'NG').length;

  const formatYen = v => v ? Number(v).toLocaleString() : '';

  let html = `
    <div style="margin-bottom:10px; font-size:12px; color:var(--ink-soft); padding:8px 12px; background:#f8fafc; border-left:3px solid var(--accent); border-radius:3px;">
      ※ 振込者(おなまえ)は払込取扱票の画像内に手書き記入されているため、各行の「画像表示」から目視確認してください。
    </div>
    <div class="table-wrap">
      <table class="result-table">
        <thead>
          <tr>
            <th style="width:50px;">No.</th>
            <th style="width:90px;">判定</th>
            <th style="width:60px;">PDFページ</th>
            <th>一連番号 (PDF)</th>
            <th>一連番号 (CSV)</th>
            <th>取扱店 (PDF)</th>
            <th>取扱店 (CSV)</th>
            <th class="num">払込金額</th>
            <th>振込者確認</th>
          </tr>
        </thead>
        <tbody>
  `;

  results.forEach((r, i) => {
    const statusBadge = r.status === 'OK'
      ? '<span class="badge ok">一致</span>'
      : '<span class="badge ng">不一致</span>';

    const slipCellPdf = r.pdfSlip
      ? (r.slipMatch ? r.pdfSlip : `<span style="color:var(--ng);font-weight:600">${r.pdfSlip || '—'}</span>`)
      : '<span style="color:var(--ink-soft)">—</span>';
    const slipCellCsv = r.csvSlip || '<span style="color:var(--ink-soft)">—</span>';
    const branchCellPdf = r.pdfBranch
      ? (r.branchMatch ? r.pdfBranch : `<span style="color:var(--ng);font-weight:600">${r.pdfBranch || '—'}</span>`)
      : '<span style="color:var(--ink-soft)">—</span>';
    const branchCellCsv = r.csvBranch || '<span style="color:var(--ink-soft)">—</span>';

    let typeLabel = '';
    if (r.type === 'pdf_only') typeLabel = ' <span class="badge neutral">PDFのみ</span>';
    else if (r.type === 'csv_only') typeLabel = ' <span class="badge neutral">CSVのみ</span>';

    const previewCell = r.pdfPageRef
      ? `<a class="preview-link" data-page="${r.pdfPage}">🔍 画像表示</a>`
      : '<span style="color:var(--ink-soft); font-size:11px;">—</span>';

    // 振替受入明細票の場合はテキスト抽出済みの payer を表示
    const payerInfo = r.pdfPageRef && r.pdfPageRef.payer
      ? `<div style="font-size:11px; color:var(--ink-soft); margin-top:2px;">${r.pdfPageRef.payer}</div>`
      : '';

    html += `
      <tr>
        <td>${i + 1}</td>
        <td>${statusBadge}${typeLabel}</td>
        <td>${r.pdfPage || '—'}</td>
        <td class="num">${slipCellPdf}</td>
        <td class="num">${slipCellCsv}</td>
        <td>${branchCellPdf}</td>
        <td>${branchCellCsv}</td>
        <td class="num">${r.pdfAmount ? '¥' + formatYen(r.pdfAmount) : ''}</td>
        <td>${previewCell}${payerInfo}</td>
      </tr>
    `;
  });

  html += '</tbody></table></div>';

  // 詳細欄(PDF全件 — 検査用)
  html += `<div style="margin-top:16px; font-size:11.5px; color:var(--ink-soft);">
    判定基準: 一連番号(8桁) ＝ 取扱店名 が PDF と CSV で完全一致した場合「一致」
  </div>`;

  document.getElementById('resultArea').innerHTML = html;

  // プレビューリンク
  document.querySelectorAll('.preview-link').forEach(el => {
    el.addEventListener('click', () => {
      const pageNum = parseInt(el.dataset.page);
      const pg = state.pdfPages.find(p => p.pageIndex === pageNum);
      if (pg) showPreview(pg);
    });
  });
}

// ========== プレビューモーダル ==========
function showPreview(pg) {
  document.getElementById('modalTitle').textContent =
    `ページ ${pg.pageIndex} / 一連番号: ${pg.slipNumber || '—'} / 取扱店: ${pg.branch || '—'}`;
  document.getElementById('modalBody').innerHTML =
    `<img src="${pg.canvasDataUrl}" alt="page ${pg.pageIndex}" />`;
  document.getElementById('modal').classList.add('show');
}
function closeModal() {
  document.getElementById('modal').classList.remove('show');
}
document.getElementById('modal').addEventListener('click', (e) => {
  if (e.target.id === 'modal') closeModal();
});

// ========== Excel ダウンロード ==========
document.getElementById('btnExcel').addEventListener('click', () => {
  const results = state.matchResults;
  const sheetData = [
    ['No.', '判定', '区分', 'PDFページ', '一連番号(PDF)', '一連番号(CSV)', '取扱店(PDF)', '取扱店(CSV)', '振込者(画像確認)', '払込金額(PDF)', '一連番号一致', '取扱店一致']
  ];
  const typeMap = { matched: '突合済', pdf_only: 'PDFのみ', csv_only: 'CSVのみ' };
  results.forEach((r, i) => {
    const payerNote = r.pdfPageRef
      ? (r.pdfPageRef.payer || '画像で目視確認')
      : '';
    sheetData.push([
      i + 1,
      r.status === 'OK' ? '一致' : '不一致',
      typeMap[r.type] || '',
      r.pdfPage || '',
      r.pdfSlip || '',
      r.csvSlip || '',
      r.pdfBranch || '',
      r.csvBranch || '',
      payerNote,
      r.pdfAmount ? Number(r.pdfAmount) : '',
      r.slipMatch ? '○' : '×',
      r.branchMatch ? '○' : '×',
    ]);
  });

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(sheetData);
  // 列幅
  ws['!cols'] = [
    { wch: 5 }, { wch: 8 }, { wch: 10 }, { wch: 9 }, { wch: 14 }, { wch: 14 },
    { wch: 12 }, { wch: 12 }, { wch: 14 }, { wch: 12 }, { wch: 10 }, { wch: 10 }
  ];
  XLSX.utils.book_append_sheet(wb, ws, '突合結果');

  // サマリーシート
  const summary = [
    ['項目', '件数'],
    ['PDF取扱票件数', state.pdfPages.filter(p => p.isSlip || p.isFurikae).length],
    ['CSV明細件数', state.csvRows.length],
    ['一致', results.filter(r => r.status === 'OK').length],
    ['不一致', results.filter(r => r.status === 'NG').length],
    [],
    ['出力日時', new Date().toLocaleString('ja-JP')],
  ];
  const wsSum = XLSX.utils.aoa_to_sheet(summary);
  wsSum['!cols'] = [{ wch: 20 }, { wch: 18 }];
  XLSX.utils.book_append_sheet(wb, wsSum, 'サマリー');

  const ymd = new Date().toISOString().slice(0, 10).replace(/-/g, '');
  XLSX.writeFile(wb, `突合結果_${ymd}.xlsx`);
});

// ========== PDF分割 ZIP ダウンロード ==========
// ファイル名: 一連番号_取扱店名.pdf
document.getElementById('btnPdfZip').addEventListener('click', async () => {
  if (!state.pdfBytes) return;
  const btn = document.getElementById('btnPdfZip');
  const original = btn.innerHTML;
  btn.disabled = true;
  btn.textContent = '分割中…';

  try {
    const { PDFDocument } = PDFLib;
    const srcDoc = await PDFDocument.load(state.pdfBytes);
    const zip = new JSZip();

    for (let i = 0; i < state.pdfPages.length; i++) {
      const meta = state.pdfPages[i];
      const newDoc = await PDFDocument.create();
      const [copied] = await newDoc.copyPages(srcDoc, [meta.pageIndex - 1]);
      newDoc.addPage(copied);
      const bytes = await newDoc.save();

      // ファイル名生成: 一連番号_支店名.pdf
      // 一連番号がない場合は page番号_pageType
      let filename;
      const safeBranch = (meta.branch || '不明').replace(/[\\/:*?"<>|]/g, '_');
      if (meta.slipNumber && (meta.isSlip || meta.isFurikae)) {
        filename = `${meta.slipNumber}_${safeBranch}.pdf`;
      } else {
        filename = `page${String(meta.pageIndex).padStart(3, '0')}_${meta.pageType}.pdf`;
      }
      zip.file(filename, bytes);
    }

    const blob = await zip.generateAsync({ type: 'blob' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const ymd = new Date().toISOString().slice(0, 10).replace(/-/g, '');
    a.download = `分割PDF_${ymd}.zip`;
    a.click();
    URL.revokeObjectURL(url);
  } catch (err) {
    alert('PDF分割エラー: ' + err.message);
    console.error(err);
  } finally {
    btn.disabled = false;
    btn.innerHTML = original;
  }
});

// ========== 印刷 ==========
document.getElementById('btnPrint').addEventListener('click', () => {
  window.print();
});
</script>

